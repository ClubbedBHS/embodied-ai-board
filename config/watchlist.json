  "queries": {
    "include_any": [
      "embodied AI", "robot learning", "vision-language-action", "VLA", "world action model",
      "robot foundation model", "generalist robot", "diffusion policy", "imitation learning robot",
      "humanoid control", "dexterous manipulation", "mobile manipulation", "robot simulator",
      "robotics benchmark", "robot dataset", "sim-to-real"
    ],
    "exclude_unless_robot_evidence": [
      "autonomous driving", "medical imaging", "pure language model", "image generation",
      "video generation", "game agent", "software agent"
    ]
  }
