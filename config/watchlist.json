{
  "version": "0.1",
  "updated_at": "2026-07-22",
  "purpose": "Embodied AI Board 的论文发现观察名单。命中观察名单只提高发现优先级，不直接增加论文质量分。",
  "identity_policy": {
    "organization": "优先使用实验室或机构官网的稳定 URL 作为身份依据。",
    "author": "优先使用 Semantic Scholar authorId、ORCID 或个人主页；不得只凭姓名去重。",
    "scoring": "watchlist 命中仅写入 discovery_signals，不计入 selection-rubric 的 100 分。"
  },
  "sources": [
    {
      "id": "arxiv",
      "name": "arXiv",
      "type": "paper-index",
      "url": "https://arxiv.org/",
      "priority": 1,
      "cadence": "daily",
      "notes": "按关键词和 cs.RO、cs.AI、cs.CV、cs.LG 交叉发现；元数据从摘要页读取，全文优先 ar5iv 或 arXiv HTML。"
    },
    {
      "id": "huggingface-daily-papers",
      "name": "Hugging Face Daily Papers",
      "type": "recommendation-feed",
      "url": "https://huggingface.co/papers",
      "priority": 2,
      "cadence": "daily",
      "notes": "用于发现热度候选；点赞或讨论量不能作为质量分。"
    },
    {
      "id": "semantic-scholar-recommendations",
      "name": "Semantic Scholar Recommendations API",
      "type": "recommendation-api",
      "url": "https://api.semanticscholar.org/api-docs/recommendations",
      "priority": 2,
      "cadence": "twice-weekly",
      "notes": "以已收录高质量论文作为 positive seeds，以已拒绝或明显偏题论文作为 negative seeds。"
    },
    {
      "id": "openreview",
      "name": "OpenReview",
      "type": "venue-index",
      "url": "https://openreview.net/",
      "priority": 2,
      "cadence": "twice-weekly",
      "notes": "关注 CoRL、ICLR、NeurIPS 等 venue 的新投稿、修订与公开评审；评审分数只作证据之一。"
    },
    {
      "id": "github-releases",
      "name": "GitHub Releases",
      "type": "asset-feed",
      "url": "https://github.com/",
      "priority": 3,
      "cadence": "twice-weekly",
      "notes": "发现论文配套代码、数据、模型和仿真器更新，不用 star 数替代研究质量判断。"
    }
  ],
